---
// The timeline: the catalogue's chronological sibling — an era-colored
// chronological spine. Multi-entry years render as one diamond marker
// with several cards; variants sit at their OWN year, never nested under
// their hub's. Data comes from timelineData() — the same derived artifact
// served at /timeline.json.
import Base from '../layouts/Base.astro';
import { eraShortName } from '../lib/content';
import { timelineData } from '../lib/derived';

const timeline = await timelineData();
const total = timeline.reduce(
  (n, era) => n + era.years.reduce((m, y) => m + y.entries.length, 0),
  0
);
// True data range, never hardcoded (the last entry may sit past its era's
// formal end — e.g. ai-designed-polymers, 2020). Rendered open-ended
// ("2020+"): the Atlas keeps growing.
const allYears = timeline.flatMap((era) => era.years.map((y) => y.year));
const yearFirst = Math.min(...allYears);
const yearLast = Math.max(...allYears);
---

<Base
  title="Timeline"
  description={`Every entry of the Atlas of Polymers on one line of time — ${total} polymers and concepts across seven eras, ${yearFirst} to ${yearLast} and counting.`}
  current="timeline"
>
  <main>
    <header class="tl-head">
      <h1 class="tl-title">The Timeline</h1>
      <p class="tl-sub">{total} entries along one line of time, {yearFirst} → {yearLast}+</p>
    </header>
    <div class="timeline">
      {
        timeline.map((era) => (
          <section class={`tl-era era-c-${era.index}`} id={`era-${era.index}`}>
            <header class="tl-era-head">
              <h2 class="tl-era-name">{eraShortName(era.name)}</h2>
              <span class="tl-era-range">
                {era.year_start}–{era.year_end}
              </span>
            </header>
            {era.years.map(({ year, entries }) => (
              <div class="tl-year-group">
                <span class="tl-year-label">{year}</span>
                <div class="tl-cards">
                  {entries.map((entry) => (
                    <a
                      class:list={['tl-card', { 'tl-card--concept': entry.concept }]}
                      href={entry.path}
                    >
                      <span class="tl-card-name" transition:name={`ed-${entry.id}`}>
                        {entry.title}
                      </span>
                      {entry.subtitle && <span class="tl-card-sub">{entry.subtitle}</span>}
                      {entry.concept && <span class="chip">concept</span>}
                    </a>
                  ))}
                </div>
              </div>
            ))}
          </section>
        ))
      }
    </div>
  </main>
</Base>
