---
// The reader's menu — a colophon-style dropdown behind an elegant trigger
// (three stacked lozenges, the same diamond motif as the timeline's year
// markers; deliberately not a hamburger). Holds the reading preferences
// that used to crowd the header: the Gilt/Vellum/Atelier presentation
// styles (each option typeset in the face it switches to) and the
// Day/Night theme pair. Absorbs the former VariantToggle + ThemeToggle
// (same localStorage keys 'pa-variant'/'pa-theme'; the Layout's pre-paint
// head script still applies both before first paint).
//
// Extensible by design: each `.menu-group` is an independent section with
// its own hairline-flanked label — future entries (links, tools) are added
// as new groups, not squeezed into the header.
import { VARIANTS } from '../../lib/variants';
---

<div class="head-menu" data-head-menu>
  <button
    class="head-icon-btn"
    type="button"
    aria-label="Reading preferences"
    title="Reading preferences"
    aria-haspopup="true"
    aria-expanded="false"
    data-menu-trigger
  >
    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M12 2.8l2.1 2.5L12 7.8 9.9 5.3z"></path>
      <path d="M12 9.5l2.1 2.5-2.1 2.5-2.1-2.5z"></path>
      <path d="M12 16.2l2.1 2.5-2.1 2.5-2.1-2.5z"></path>
    </svg>
  </button>

  <div class="head-menu-panel" aria-label="Reading preferences" data-menu-panel>
    <section class="menu-group" aria-label="Presentation style">
      <h2 class="menu-group-label u-caps menu-stagger">Presentation</h2>
      {
        VARIANTS.map((v) => (
          <button
            class="menu-option menu-stagger"
            type="button"
            data-variant-btn={v.id}
            title={v.note}
          >
            <span class="menu-option-text">
              <span class={`menu-option-name menu-option-name--${v.id}`}>{v.name}</span>
              <span class="menu-option-note">{v.essence}</span>
            </span>
            <span class="menu-option-mark" aria-hidden="true">✦</span>
          </button>
        ))
      }
    </section>

    <section class="menu-group" aria-label="Theme">
      <h2 class="menu-group-label u-caps menu-stagger">Light</h2>
      <div class="menu-pair menu-stagger">
        <button class="menu-pair-btn" type="button" data-theme-set="light">
          <svg
            width="15"
            height="15"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            aria-hidden="true"
          >
            <circle cx="12" cy="12" r="4.6"></circle>
            <path
              d="M12 2.5v2.2M12 19.3v2.2M2.5 12h2.2M19.3 12h2.2M5.2 5.2l1.6 1.6M17.2 17.2l1.6 1.6M18.8 5.2l-1.6 1.6M6.8 17.2l-1.6 1.6"
            ></path>
          </svg>
          Day
        </button>
        <button class="menu-pair-btn" type="button" data-theme-set="dark">
          <svg
            width="15"
            height="15"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M20.2 14.5A8.6 8.6 0 0 1 9.5 3.8a8.6 8.6 0 1 0 10.7 10.7z"></path>
          </svg>
          Night
        </button>
      </div>
    </section>

    <section class="menu-group" aria-label="Units">
      <h2 class="menu-group-label u-caps menu-stagger">Units</h2>
      <div class="menu-pair menu-stagger">
        <button class="menu-pair-btn" type="button" data-units-set="si">
          <span class="menu-pair-glyph" aria-hidden="true">°C</span>
          SI
        </button>
        <button class="menu-pair-btn" type="button" data-units-set="imperial">
          <span class="menu-pair-glyph" aria-hidden="true">°F</span>
          Imperial
        </button>
      </div>
    </section>
  </div>
</div>

<script>
  import { imperialText, siText } from '../../lib/units';

  // All listeners delegated on document — they survive View Transitions.
  const VARIANT_IDS = ['gilt', 'vellum', 'atelier'];

  function applyVariant(v: string) {
    const root = document.documentElement;
    for (const id of VARIANT_IDS) root.classList.toggle(`variant-${id}`, id === v);
  }

  function storedVariant(): string {
    try {
      const v = localStorage.getItem('pa-variant');
      if (v && VARIANT_IDS.includes(v)) return v;
    } catch {
      /* ignore */
    }
    return 'gilt';
  }

  function resolvedTheme(): string {
    const forced = document.documentElement.dataset.theme;
    if (forced === 'light' || forced === 'dark') return forced;
    return matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
  }

  function storedUnits(): string {
    try {
      if (localStorage.getItem('pa-units') === 'imperial') return 'imperial';
    } catch {
      /* ignore */
    }
    return 'si';
  }

  // Rewrite every convertible property value in place. The SI numbers live
  // in data attributes stamped at build time (PropRow); SI text is
  // regenerated through the same assembler that produced the server HTML,
  // so toggling back is byte-identical.
  function applyUnits(system: string) {
    document.querySelectorAll<HTMLElement>('[data-si-unit]').forEach((el) => {
      const num = (s: string | undefined) => (s != null && s !== '' ? Number(s) : null);
      const v = num(el.dataset.siV);
      const min = num(el.dataset.siMin);
      const max = num(el.dataset.siMax);
      const unit = el.dataset.siUnit ?? '';
      const text =
        system === 'imperial'
          ? imperialText(v, min, max, unit)
          : siText(v, min, max, unit);
      if (text !== null) el.textContent = text;
    });
  }

  // Mirror the current variant/theme/units onto the menu's active marks.
  function syncMenu() {
    const v = VARIANT_IDS.find((id) =>
      document.documentElement.classList.contains(`variant-${id}`)
    );
    const t = resolvedTheme();
    const u = storedUnits();
    document.querySelectorAll<HTMLElement>('[data-variant-btn]').forEach((b) => {
      b.classList.toggle('is-active', b.dataset.variantBtn === v);
    });
    document.querySelectorAll<HTMLElement>('[data-theme-set]').forEach((b) => {
      b.classList.toggle('is-active', b.dataset.themeSet === t);
    });
    document.querySelectorAll<HTMLElement>('[data-units-set]').forEach((b) => {
      b.classList.toggle('is-active', b.dataset.unitsSet === u);
    });
  }

  function setOpen(menu: Element, open: boolean) {
    menu.classList.toggle('is-open', open);
    menu.querySelector('[data-menu-trigger]')?.setAttribute('aria-expanded', String(open));
    if (open) syncMenu();
  }

  document.addEventListener('click', (e) => {
    const el = e.target as Element | null;
    const menu = document.querySelector('[data-head-menu]');
    if (!menu) return;

    if (el?.closest('[data-menu-trigger]')) {
      setOpen(menu, !menu.classList.contains('is-open'));
      return;
    }

    // Style/theme choices apply live behind the open panel — the page
    // transforms while the menu stays up, so the choice reads immediately.
    const vBtn = el?.closest<HTMLElement>('[data-variant-btn]');
    if (vBtn?.dataset.variantBtn) {
      applyVariant(vBtn.dataset.variantBtn);
      try {
        localStorage.setItem('pa-variant', vBtn.dataset.variantBtn);
      } catch {
        /* storage unavailable — switch still applies to this page */
      }
      syncMenu();
      return;
    }
    const tBtn = el?.closest<HTMLElement>('[data-theme-set]');
    if (tBtn?.dataset.themeSet) {
      document.documentElement.dataset.theme = tBtn.dataset.themeSet;
      try {
        localStorage.setItem('pa-theme', tBtn.dataset.themeSet);
      } catch {
        /* ignore */
      }
      syncMenu();
      return;
    }
    const uBtn = el?.closest<HTMLElement>('[data-units-set]');
    if (uBtn?.dataset.unitsSet) {
      try {
        localStorage.setItem('pa-units', uBtn.dataset.unitsSet);
      } catch {
        /* storage unavailable — conversion still applies to this page */
      }
      applyUnits(uBtn.dataset.unitsSet);
      syncMenu();
      return;
    }

    // Anywhere else closes it.
    if (!el?.closest('[data-head-menu]')) setOpen(menu, false);
  });

  document.addEventListener('keydown', (e) => {
    if (e.key !== 'Escape') return;
    const menu = document.querySelector('[data-head-menu].is-open');
    if (menu) setOpen(menu, false);
  });

  // Initial load + every swap: re-apply the stored preferences (the swap
  // resets <html>'s class list and attributes to the server-rendered
  // default) and re-sync the marks.
  function restore() {
    applyVariant(storedVariant());
    try {
      const t = localStorage.getItem('pa-theme');
      if (t === 'light' || t === 'dark') document.documentElement.dataset.theme = t;
    } catch {
      /* ignore */
    }
    applyUnits(storedUnits());
    syncMenu();
  }
  document.addEventListener('astro:page-load', restore);
  document.addEventListener('astro:after-swap', restore);
</script>
