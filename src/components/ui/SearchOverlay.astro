---
// Full-text search: custom UI over Pagefind's JS API — never the
// prebuilt widget. Since 2026-07-22 it is a header DROPDOWN panel sharing
// the EditionMenu's anatomy (.head-menu/.head-menu-panel, hairline-flanked
// label, staggered unfold) instead of a modal <dialog> — one coherent
// header language. The Pagefind bundle is produced post-build
// (`pagefind --site dist`), lazy-loaded on first open, and filterable by
// the type/era metadata stamped on every detail page. In `astro dev` the
// bundle doesn't exist; the panel shows an honest notice instead.
import { eras, eraShortName, href } from '../../lib/content';
---

<div class="head-menu head-search" data-head-search>
  <button
    class="head-icon-btn"
    type="button"
    aria-label="Search the atlas"
    title="Search — Ctrl K or /"
    aria-haspopup="true"
    aria-expanded="false"
    data-search-open
  >
    <svg
      width="18"
      height="18"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.6"
      stroke-linecap="round"
      aria-hidden="true"
    >
      <circle cx="10.8" cy="10.8" r="6.3"></circle>
      <path d="M15.5 15.5L20.4 20.4"></path>
    </svg>
  </button>

  <div class="head-menu-panel search-panel" role="search" aria-label="Search the atlas">
    <h2 class="menu-group-label u-caps menu-stagger">Search the Atlas</h2>
    <form class="search-bar menu-stagger" data-search-form>
      <input
        type="search"
        placeholder="Names, aliases, properties, history…"
        autocomplete="off"
        data-search-input
      />
    </form>
    <div class="search-filters menu-stagger">
      <select aria-label="Type" data-search-type>
        <option value="">All types</option>
        <option value="polymer">Polymers</option>
        <option value="concept">Concepts</option>
      </select>
      <select aria-label="Era" data-search-era>
        <option value="">Any era</option>
        {eras.map((era) => <option value={eraShortName(era.name)}>{eraShortName(era.name)}</option>)}
      </select>
      <span class="search-count" data-search-count></span>
    </div>
    <ol class="search-results" data-search-results></ol>
  </div>
</div>

<script is:inline define:vars={{ pagefindPath: href('/pagefind/pagefind.js') }}>
  window.__pagefindPath = pagefindPath;
</script>

<script>
  // Module scope survives View Transitions; all listeners are delegated on
  // document so re-rendered panels keep working after swaps.
  let pagefind: any = null;
  let loadFailed = false;
  let debounceTimer: ReturnType<typeof setTimeout> | undefined;

  const q = <T extends Element>(sel: string) => document.querySelector<T>(sel);

  // Indirect dynamic import the bundler cannot see. A literal
  // `import(path)` here breaks under Astro 7/Vite 8: the `@vite-ignore`
  // hint is stripped from component scripts, Vite wraps the call in its
  // preload helper, and the `__VITE_PRELOAD__` placeholder is left
  // unresolved in the built page — a runtime ReferenceError that silently
  // put the UI in its "index not available" state (caught 2026-07-22).
  const importRuntime = new Function('path', 'return import(path)') as (
    p: string
  ) => Promise<any>;

  async function ensurePagefind() {
    if (pagefind || loadFailed) return;
    try {
      pagefind = await importRuntime((window as any).__pagefindPath);
      await pagefind.options({ excerptLength: 22 });
      pagefind.init();
    } catch {
      loadFailed = true;
    }
  }

  function setSearchOpen(open: boolean) {
    const root = q('[data-head-search]');
    if (!root) return;
    root.classList.toggle('is-open', open);
    root.querySelector('[data-search-open]')?.setAttribute('aria-expanded', String(open));
    if (open) {
      ensurePagefind().then(runSearch);
      q<HTMLInputElement>('[data-search-input]')?.focus();
    }
  }

  async function runSearch() {
    const input = q<HTMLInputElement>('[data-search-input]');
    const results = q<HTMLOListElement>('[data-search-results]');
    const count = q<HTMLElement>('[data-search-count]');
    if (!input || !results || !count) return;
    if (loadFailed) {
      count.textContent = '';
      results.innerHTML =
        '<li class="search-empty">Search index not available — it is generated by the production build (<code>pagefind --site dist</code>), not the dev server.</li>';
      return;
    }
    const term = input.value.trim();
    const type = q<HTMLSelectElement>('[data-search-type]')?.value ?? '';
    const era = q<HTMLSelectElement>('[data-search-era]')?.value ?? '';
    if (!term && !type && !era) {
      results.innerHTML = '';
      count.textContent = '';
      return;
    }
    const filters: Record<string, string> = {};
    if (type) filters.type = type;
    if (era) filters.era = era;
    const search = await pagefind.search(term || null, { filters });
    const top = await Promise.all(search.results.slice(0, 12).map((r: any) => r.data()));
    count.textContent = `${search.results.length} result${search.results.length === 1 ? '' : 's'}`;
    results.innerHTML = top
      .map(
        (d: any) => `
        <li>
          <a class="search-result" href="${d.url}">
            <span class="search-result-head">
              <span class="search-result-title">${d.meta.title ?? ''}</span>
              ${d.meta.year ? `<span class="search-result-year">${d.meta.year}</span>` : ''}
            </span>
            ${d.meta.subtitle ? `<span class="search-result-sub">${d.meta.subtitle}</span>` : ''}
            <span class="search-result-excerpt">${d.excerpt}</span>
          </a>
        </li>`
      )
      .join('');
  }

  document.addEventListener('click', (e) => {
    const el = e.target as Element | null;
    if (el?.closest('[data-search-open]')) {
      const root = q('[data-head-search]');
      setSearchOpen(!root?.classList.contains('is-open'));
      return;
    }
    // Anywhere outside the search area closes it (result links navigate
    // normally first — ClientRouter swaps in a closed panel).
    if (!el?.closest('[data-head-search]')) setSearchOpen(false);
  });

  document.addEventListener('keydown', (e) => {
    if ((e.ctrlKey || e.metaKey) && e.key.toLowerCase() === 'k') {
      e.preventDefault();
      setSearchOpen(true);
    }
    if (
      e.key === '/' &&
      !(e.target instanceof HTMLInputElement) &&
      !(e.target instanceof HTMLTextAreaElement)
    ) {
      e.preventDefault();
      setSearchOpen(true);
    }
    if (e.key === 'Escape') setSearchOpen(false);
  });

  document.addEventListener('input', (e) => {
    const el = e.target as Element | null;
    if (!el?.closest('.search-panel')) return;
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(runSearch, 150);
  });

  document.addEventListener('submit', (e) => {
    if (!(e.target as Element | null)?.matches('[data-search-form]')) return;
    e.preventDefault();
    const first = q<HTMLAnchorElement>('.search-result');
    if (first) window.location.href = first.href;
  });
</script>
